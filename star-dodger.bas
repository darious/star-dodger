10 :'**    STAR DODGER v2   **
20 :'** G. French (14-2-92) **
30 :'
40 :'** SET UP **
50 DEFINT a-z:GOSUB 1110
60 ENV 1,15,-1,10:ENT 1,15,-1,10
70 :'** INSTRUCTIONS **
80 MODE 1:fin=0:q=5:sp=0
90 INK 0,0:BORDER 0:INK 2,26:INK 3,0
100 INK 1,21:SPEED INK 2,10
110 a$="StarDodger":a=17:y=1:GOSUB 1160
120 a$="Avoid the killer Asterisks, and seek the":a=2:y=5:GOSUB 1160
130 a$="wondrous Nextscreen Gap.":a=10:y=6:GOSUB 1160
140 a$="Use SPACE to climb":a=13:y=13:GOSUB 1160
150 a$="Do you want the slow speed Y/N":a=8:y=16:GOSUB 1160
160 a$=UPPER$(INKEY$):IF a$="Y" THEN sd=1 ELSE IF a$="N" THEN sd=0 ELSE 160
170 GOSUB 550
180 :'** GAME SCREEN **
190 MODE 1:yt=228:yb=172
200 DRAWR 629,0,2:DRAWR 0,170:MOVER 0,60
210 DRAWR 0,169:DRAWR -629,0:DRAWR 0,-399
220 DRAWR 0,2:DRAWR 627,0:DRAWR 0,168
230 MOVER 0,60:DRAWR 0,167:DRAWR -625,0
240 DRAWR 0,-399:MOVE 636,0:DRAW 636,399,3
250 MOVE 638,0:DRAW 638,399:PLOT -1,-1,1
260 IF q>=45 THEN INK 1,21,0:sp=sp+1:SPEED INK 3,1+sp
270 IF sd THEN d=3 ELSE d=4
280 TAG:FOR s=1 TO q
290 MOVE 50+RND*561,20+RND*361
300 PRINT"*";:NEXT:TAGOFF:MOVE 0,200
310 IF q>55 THEN EVERY 25,2 GOSUB 1230
320 dd=d
330 :'** THE GAME **
340 DRAWR dd,d,2
350 IF INKEY(47)=0 THEN d=dd ELSE d=-dd
360 t=TESTR(2,d/2)
370 IF t=1 OR t=2 GOTO 410
380 IF t=3 THEN SOUND 1,50,150,15,1,1:GOTO 510
390 MOVER -2,-d/2:GOTO 340
400 :'** HIT SUMMIT' NASTY **
410 i=REMAIN(2):SOUND 1,0,150,15,1,,31
420 BORDER 26:INK 0,26:INK 1,0:INK 2,0
430 INK 1,21:INK 2,26
440 MODE 1:BORDER 0:INK 0,0:scr=(q/5)-1
450 a$="YOU WERE ZAPPED BY A KILLER ASTERISK":a=4:y=1:GOSUB 1160
460 a$="Number of screens completed = "+STR$(scr):a=6:y=13:GOSUB 1160
470 GOSUB 550
480 IF scr>h(6) THEN GOTO 600
490 fin=1:GOTO 600
500 :'** COMPLETED SCREEN **
510 MODE 1:i=REMAIN(2)
520 a$="YOU MADE IT THROUGH THE KILLER ASTERISKS":a=2:y=1:GOSUB 1160
530 a$="Stand by for Screen "+STR$((Q/5)+1):a=11:y=13:GOSUB 1160
540 GOSUB 550:q=q+5:GOTO 190
550 a$="Press any key to continue."
560 a=9:y=25:GOSUB 1160
570 WHILE INKEY$<>"":WEND:CALL &BB18
580 RETURN
590 :'** ENTER NAME INTO HALL OF FAME **
600 MODE 0:s=2:EVERY 5 GOSUB 1060
610 EVERY 3,1 GOSUB 1070
620 IF fin THEN 920
630 FOR n=3 TO 15:INK n,0:NEXT:PEN 1
640 LOCATE 4,1:PRINT"** WELL DONE **"
650 INK 2,26:PEN 2:PRINT
660 PRINT" YOU ARE ONE OF THE ":PRINT
670 PRINT"  BEST STARDODGERS  ":PRINT
680 PRINT"  IN THE UNIVERSE."
690 a$="ENTER YOUR NAME"
700 PRINT:PRINT:PRINT:PRINT TAB(3);
710 z=3:FOR n=1 TO LEN(a$)
720 x$=MID$(a$,n,1):IF x$=" " THEN PRINT" ";:GOTO 740
730 PEN z:PRINT x$;:z=z+1
740 NEXT
750 LOCATE 7,15:PEN 2:PRINT">------<"
760 h$="":FOR n=1 TO 7:LOCATE n+7,15
770 a$=UPPER$(INKEY$):IF a$="" THEN 770
780 IF a$=CHR$(13) THEN n=8:GOTO 830
790 IF a$=CHR$(127) THEN n=8:q=1:GOTO 830
800 IF a$<" " OR a$>"~" THEN 770
810 IF n=7 THEN 770
820 PEN 1:PRINT a$;:h$=h$+a$
830 NEXT n:IF q=1 THEN q=0:GOTO 750
840 h$(7)=h$:h(7)=scr
850 w=1:WHILE w:w=0:FOR i=2 TO 7
860 IF h(i)>h(i-1) THEN GOSUB 880
870 NEXT:WEND:GOTO 920
880 a$=h$(i):a=h(i):h$(i)=h$(i-1)
890 h(i)=h(i-1):h$(i-1)=a$:h(i-1)=a
900 w=1:RETURN
910 :'** DISPLAY HALL OF FAME **
920 CLS:PEN 1:PRINT"  ** THE TOP SIX **"
930 x=REMAIN(1):RESTORE 950
940 FOR n=2 TO 7:READ i:INK n,i:NEXT
950 DATA 6,15,24,21,11,8
960 LOCATE 1,4:FOR n=1 TO 6:PEN n+1
970 PRINT USING"  \         \  ###";h$(n),h(n)
980 PRINT:NEXT
990 LOCATE 1,25:INK 8,26:PEN 8
1000 PRINT"   PRESS SPACE BAR";
1010 WHILE INKEY$<>"":WEND
1020 WHILE INKEY$<>" ":WEND:MODE 1
1030 INK 3,26:INK 1,26:INK 2,26:PEN 1
1040 x=REMAIN(0):GOTO 80
1050 :'** INK FLASH INTERRUPTS **
1060 INK 1,INT(RND*26)+1:RETURN
1070 IF s>15 THEN s=15:t=0:st=-1
1080 IF s<3 THEN s=3:t=21:st=1
1090 INK s,t:s=s+st:RETURN
1100 :'** INITIALISE **
1110 DIM h$(7),h(7):RESTORE 1130
1120 FOR n=1 TO 6:READ h$(n),h(n):NEXT
1130 DATA GRAHAM,12,EGGY,10,NOB,8,MARK,6,SARAH,4,HILARY,2
1140 RETURN
1150 :'** MESSAGE PRINT ROUTINE **
1160 INK 1,21:FOR n=a TO a+LEN(a$)-1
1170 LOCATE n,y:PEN 1:PRINT"*"
1180 LOCATE n-1,y:PEN 2
1190 PRINT MID$(a$,n-(a-1),1):NEXT
1200 LOCATE a+LEN(a$)-1,y:PRINT" "
1210 RETURN
1220 :'** GAP CLOSE INTERRUPT **
1230 x1=XPOS:y1=YPOS
1240 PLOT 629,yb,2:PLOT 629,yt
1250 PLOT 627,yb:PLOT 627,yt
1260 yt=yt-2:yb=yb+2:MOVE x1,y1:RETURN

